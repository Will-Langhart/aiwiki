# ============================================================================
# Public (client-safe — exposed via Vite import.meta.env)
# ============================================================================
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_SITE_URL=https://aiwiki.dev

# ============================================================================
# Build-time only (used by react-router.config.ts prerender in Phase 1+)
# ============================================================================
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================================================
# Edge Functions / server-only
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
RESEND_API_KEY=re_...
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...
EDGE_FUNCTION_SECRET=

# ============================================================================
# Cost caps (USD/day per feature; enforced server-side in Edge Functions)
# ============================================================================
MAX_DAILY_SPEND_USD_CHAT=10
MAX_DAILY_SPEND_USD_AUTOFILL=5
MAX_DAILY_SPEND_USD_COMPARE=3
MAX_DAILY_SPEND_USD_MODERATE=2
