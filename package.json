{
  "name": "ai-wiki",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "prebuild": "tsx scripts/generate-sitemap.ts",
    "build": "react-router build",
    "sitemap": "tsx scripts/generate-sitemap.ts",
    "preview": "react-router-serve ./build/server/index.js",
    "lint": "biome lint ./app ./supabase/functions",
    "format": "biome format --write ./app",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:e2e": "playwright test",
    "db:types": "supabase gen types typescript --local > ./app/types/database.ts",
    "db:seed": "npx tsx scripts/seed.ts",
    "db:seed-bulk": "npx tsx scripts/seed-bulk.ts",
    "db:discover": "npx tsx scripts/discover-tools.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@hookform/resolvers": "^5.4.0",
    "@react-router/node": "^7.15.1",
    "@supabase/supabase-js": "^2.49.4",
    "@tanstack/react-query": "^5.74.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.2.1",
    "lucide-react": "^0.475.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.54.2",
    "react-markdown": "^9.0.3",
    "react-router": "^7.15.1",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.50.1",
    "@react-router/dev": "^7.15.1",
    "@react-router/serve": "^7.15.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.3",
    "dotenv": "^17.4.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9"
  }
